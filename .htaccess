# FlowStack — Apache Config
# Disable directory listing site-wide

Options -Indexes

# Default entry point
DirectoryIndex index.html index.php

# URL rewriting — works on both localhost subdirectory AND domain root
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Do NOT hardcode RewriteBase — Apache resolves it automatically

    # If file exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# Block direct access to PHP config files from browser
<FilesMatch "^(db|oauth)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

